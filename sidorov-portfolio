<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
font-family:'Montserrat',sans-serif;
background:#f5f5f5;
color:#111;
}

.hero{
height:100vh;
position:relative;
padding:42px;
overflow:hidden;
border-bottom:1px solid #e8e8e8;
}

.hero-bg{
position:absolute;
inset:0;
background:url('cover.jpg') center/contain no-repeat;
opacity:.18;
}

.nav{
position:relative;
z-index:10;
display:flex;
justify-content:space-between;
align-items:center;
font-size:12px;
letter-spacing:.08em;
}

.logo span{opacity:.4;}

.nav-right{
display:flex;
gap:42px;
align-items:center;
}

.nav-right a{
color:#111;
text-decoration:none;
}

.telegram{
padding:14px 22px;
border:1px solid #999;
}

.hero-content{
position:relative;
z-index:5;
max-width:520px;
margin-top:120px;
}

.hero-content h1{
font-size:76px;
line-height:.92;
font-weight:300;
}

.light{color:#bbb;}

.hero-content p{
margin-top:26px;
font-size:18px;
line-height:1.7;
color:#666;
}

.section-title{
padding:80px 42px 20px;
font-size:54px;
font-weight:300;
border-top:1px solid #e8e8e8;
}

.projects{
padding-bottom:40px;
}

.project{
display:grid;
grid-template-columns:180px 1fr;
gap:30px;
padding:14px 42px;
border-bottom:1px solid #ececec;
}

.meta{
padding-top:24px;
}

.num{
font-size:54px;
font-weight:300;
margin-bottom:14px;
}

.name{
font-size:22px;
margin-bottom:12px;
}

.sub{
font-size:12px;
line-height:1.7;
color:#777;
}

.frame{
background:white;
padding:18px;
display:flex;
justify-content:center;
align-items:center;
}

.frame img{
max-width:100%;
height:auto;
max-height:none;
object-fit:contain;
}

.compare{
position:relative;
background:white;
overflow:hidden;
aspect-ratio:16/8;
}

.compare img{
position:absolute;
width:100%;
height:100%;
object-fit:contain;
background:white;
}

.after{
clip-path: inset(0 50% 0 0);
}

.line{
position:absolute;
left:50%;
top:0;
width:2px;
height:100%;
background:white;
z-index:4;
}

.compare input{
position:absolute;
bottom:18px;
left:50%;
transform:translateX(-50%);
width:240px;
z-index:5;
}

.photoshop-grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:18px;
padding:0 42px 60px;
}

.ps-card{
background:white;
padding:18px;
}

.ps-card img{
width:100%;
height:auto;
display:block;
}

.video-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
padding:0 42px 80px;
}

.video-card{
background:white;
padding:24px;
min-height:260px;
display:flex;
flex-direction:column;
justify-content:space-between;
border:1px solid #ececec;
}

.video-card h3{
font-size:24px;
font-weight:300;
}

.video-card p{
font-size:14px;
line-height:1.8;
color:#666;
margin-top:14px;
}

.filename{
margin-top:20px;
font-size:12px;
letter-spacing:.08em;
color:#999;
}

.footer{
display:flex;
justify-content:space-between;
padding:28px 42px;
font-size:11px;
color:#777;
border-top:1px solid #ececec;
}

@media(max-width:900px){
.project{
grid-template-columns:1fr;
}

.photoshop-grid,
.video-grid{
grid-template-columns:1fr;
}

.hero-content h1{
font-size:48px;
}
}


.video-card video{
width:100%;
height:auto;
display:block;
background:black;
object-fit:cover;
margin-bottom:20px;
}

.video-info h3{
font-size:24px;
font-weight:300;
margin-bottom:12px;
}

.video-info p{
font-size:14px;
line-height:1.8;
color:#666;
}

</style>
</head>

